{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "tokyonight",
  "keybinds": {
    "leader": "ctrl+x"
  },
  "leader_timeout": 2000,
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": false
  },
  "diff_style": "stacked",
  "mouse": true,
  "attention": {
    "enabled": true,
    "notifications": true,
    "sound": false,
    "volume": 0,
    "sound_pack": "opencode.default",
    "sounds": {}
  },
  "plugin": ["./plugins/tui-dcp-status.tsx"],
  "plugin_enabled": {
    "tui-dcp-status": true
  }
}
